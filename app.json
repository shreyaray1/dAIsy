{
  "expo": {
    "name": "dAIsy Style",
    "slug": "StyleAI",
    "scheme": "styleai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8C9F81"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shreya.styleai",
      "infoPlist": {
        "NSCameraUsageDescription": "StyleAI uses your camera to analyze your coloring and photograph clothes for your wardrobe.",
        "NSPhotoLibraryUsageDescription": "StyleAI accesses your photo library so you can add clothing items to your wardrobe.",
        "NSPhotoLibraryAddUsageDescription": "StyleAI saves outfit photos to your library.",
        "NSLocationWhenInUseUsageDescription": "StyleAI uses your location to recommend outfits based on your local weather.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.shreya.styleai",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      "expo-location",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "922f6091-efee-4f31-8e62-eb52b0454227"
      }
    },
    "privacyPolicyUrl": "https://boulder-chemistry-ca9.notion.site/dAIsy-Privacy-Policy-39057b3ee25d80818704d4ab44a0b696"
  }
}
